{% paginate blog.articles by section.settings.posts_per_page %}
<section class="shop-section">
  <div class="page-width blog-list">
    <div class="section-heading">
      <div>
        <h1>{{ blog.title }}</h1>
        {% if blog.all_tags.size > 0 %}<p>Stories, notes, and brand updates.</p>{% endif %}
      </div>
    </div>

    {% for article in blog.articles %}
      <article class="shop-card article-card">
        <a href="{{ article.url }}" class="article-card__media">
          {% if article.image %}
            <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" width="{{ article.image.width }}" height="{{ article.image.height }}">
          {% else %}
            {{ 'image' | placeholder_svg_tag }}
          {% endif %}
        </a>
        <div class="article-content">
          <span class="badge">{{ article.published_at | date: '%d %b %Y' }}</span>
          <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
          <div class="text-muted">{{ article.excerpt_or_content | strip_html | truncate: 220 }}</div>
        </div>
      </article>
    {% endfor %}

    {% if paginate.pages > 1 %}
      <nav class="pagination" aria-label="Pagination">
        {% if paginate.previous %}<a href="{{ paginate.previous.url }}">←</a>{% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{% else %}<span{% if part.title == paginate.current_page %} aria-current="page"{% endif %}>{{ part.title }}</span>{% endif %}
        {% endfor %}
        {% if paginate.next %}<a href="{{ paginate.next.url }}">→</a>{% endif %}
      </nav>
    {% endif %}
  </div>
</section>
{% endpaginate %}

{% schema %}
{
  "name": "Main blog",
  "settings": [
    { "type": "range", "id": "posts_per_page", "min": 4, "max": 12, "step": 1, "label": "Posts per page", "default": 6 }
  ]
}
{% endschema %}
