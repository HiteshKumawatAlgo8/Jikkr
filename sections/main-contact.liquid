<section class="shop-section">
  <div class="content-width">
    <div class="shop-card article-content">
      <div class="section-heading">
        <h1>{{ page.title | default: 'Contact' }}</h1>
        <p>{{ section.settings.intro }}</p>
      </div>
      {% form 'contact', class: 'contact-form' %}
        {% if form.posted_successfully? %}
          <p class="badge field--full">{{ 'templates.contact.form.post_success' | t }}</p>
        {% endif %}
        {{ form.errors | default_errors }}
        <div class="field">
          <label for="ContactFormName">{{ 'templates.contact.form.name' | t }}</label>
          <input type="text" id="ContactFormName" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
        </div>
        <div class="field">
          <label for="ContactFormEmail">{{ 'templates.contact.form.email' | t }}</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
        </div>
        <div class="field field--full">
          <label for="ContactFormPhone">{{ 'templates.contact.form.phone' | t }}</label>
          <input type="tel" id="ContactFormPhone" name="contact[phone]" value="{{ form.phone }}">
        </div>
        <div class="field field--full">
          <label for="ContactFormBody">{{ 'templates.contact.form.comment' | t }}</label>
          <textarea rows="8" id="ContactFormBody" name="contact[body]">{{ form.body }}</textarea>
        </div>
        <div class="field--full">
          <button class="button" type="submit">{{ 'templates.contact.form.send' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main contact",
  "settings": [
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Use this contact template for brand enquiries, wholesale requests, and client conversations." }
  ]
}
{% endschema %}
