{% paginate search.results by section.settings.results_per_page %}
<section class="shop-section">
  <div class="page-width search-layout">
    <div class="section-heading">
      <div>
        <h1>{{ 'general.search.search' | t }}</h1>
        {% if search.performed %}<p>Showing results for “{{ search.terms | escape }}”</p>{% endif %}
      </div>
    </div>

    <form action="{{ routes.search_url }}" method="get" class="search-toolbar">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products, pages, and articles">
      <input type="hidden" name="options[prefix]" value="last">
      <button class="button" type="submit">Search</button>
    </form>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <div class="product-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'product-card', product: item %}
            {% else %}
              <article class="shop-card article-content">
                <span class="badge">{{ item.object_type | capitalize }}</span>
                <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                {% if item.image %}
                  <div class="shop-card" style="overflow:hidden; margin:16px 0;"> <img src="{{ item.image | image_url: width: 900 }}" alt="{{ item.image.alt | escape }}"> </div>
                {% endif %}
                <div class="text-muted">{{ item.content | strip_html | truncate: 160 }}</div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">No results matched your search.</div>
      {% endif %}
    {% else %}
      <div class="empty-state">Search the store to find products, pages, and journal entries.</div>
    {% endif %}

    {% if paginate.pages > 1 %}
      <nav class="pagination" aria-label="Pagination">
        {% if paginate.previous %}<a href="{{ paginate.previous.url }}">←</a>{% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{% else %}<span{% if part.title == paginate.current_page %} aria-current="page"{% endif %}>{{ part.title }}</span>{% endif %}
        {% endfor %}
        {% if paginate.next %}<a href="{{ paginate.next.url }}">→</a>{% endif %}
      </nav>
    {% endif %}
  </div>
</section>
{% endpaginate %}

{% schema %}
{
  "name": "Main search",
  "settings": [
    { "type": "range", "id": "results_per_page", "min": 8, "max": 24, "step": 4, "label": "Results per page", "default": 12 }
  ]
}
{% endschema %}
