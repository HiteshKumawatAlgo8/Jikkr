<section class="shop-section">
  <div class="content-width">
    <div class="shop-card article-content" style="text-align:center;">
      <span class="badge">{{ shop.name }}</span>
      <h1 class="rich-text__title">Enter the store</h1>
      {% if shop.password_message != blank %}<p class="text-muted">{{ shop.password_message }}</p>{% endif %}
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <div class="field" style="max-width:420px; margin:0 auto 16px;">
          <label for="Password">Password</label>
          <input type="password" name="password" id="Password" autocomplete="current-password">
        </div>
        <button class="button" type="submit">Enter</button>
      {% endform %}
    </div>
  </div>
</section>
