<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>Reset password</h1></div>{% form 'reset_customer_password' %}{{ form.errors | default_errors }}<div class="grid grid--2"><div class="field"><label for="ResetPassword">Password</label><input type="password" name="customer[password]" id="ResetPassword"></div><div class="field"><label for="ResetPasswordConfirmation">Confirm password</label><input type="password" name="customer[password_confirmation]" id="ResetPasswordConfirmation"></div></div><div style="margin-top:20px;"><button class="button" type="submit">Reset password</button></div>{% endform %}</div></div></section>