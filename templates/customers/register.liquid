<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>Create account</h1></div>{% form 'create_customer' %}{{ form.errors | default_errors }}<div class="grid grid--2"><div class="field"><label for="FirstName">First name</label><input type="text" name="customer[first_name]" id="FirstName"></div><div class="field"><label for="LastName">Last name</label><input type="text" name="customer[last_name]" id="LastName"></div><div class="field"><label for="RegisterEmail">Email</label><input type="email" name="customer[email]" id="RegisterEmail"></div><div class="field"><label for="RegisterPassword">Password</label><input type="password" name="customer[password]" id="RegisterPassword"></div></div><div style="margin-top:20px;"><button class="button" type="submit">Create account</button></div>{% endform %}</div></div></section>