<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>My account</h1><a class="button-secondary" href="{{ routes.account_logout_url }}">Log out</a></div><p>Welcome back, {{ customer.first_name | default: customer.email }}.</p><h2>Orders</h2>{% if customer.orders_count > 0 %}<ul class="list-unstyled">{% for order in customer.orders %}<li style="padding:12px 0; border-bottom:1px solid rgba(24,22,20,.08);"><a href="{{ order.customer_url }}">{{ order.name }}</a> — {{ order.created_at | date: '%d %b %Y' }} — {{ order.total_price | money }}</li>{% endfor %}</ul>{% else %}<p class="text-muted">No orders yet.</p>{% endif %}</div></div></section>