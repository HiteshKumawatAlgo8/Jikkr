<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>{{ order.name }}</h1><a class="button-secondary" href="{{ routes.account_url }}">Back to account</a></div><p>{{ order.created_at | date: '%d %b %Y' }}</p><ul class="list-unstyled">{% for line_item in order.line_items %}<li style="padding:12px 0; border-bottom:1px solid rgba(24,22,20,.08);">{{ line_item.title }} × {{ line_item.quantity }} — {{ line_item.final_line_price | money }}</li>{% endfor %}</ul><p style="margin-top:20px;"><strong>Total:</strong> {{ order.total_price | money }}</p></div></div></section>