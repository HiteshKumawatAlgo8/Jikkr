<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>Login</h1></div>{% form 'customer_login' %}{{ form.errors | default_errors }}<div class="grid grid--2"><div class="field"><label for="CustomerEmail">Email</label><input type="email" name="customer[email]" id="CustomerEmail"></div><div class="field"><label for="CustomerPassword">Password</label><input type="password" name="customer[password]" id="CustomerPassword"></div></div><div style="margin-top:20px; display:flex; gap:12px; flex-wrap:wrap;"><button class="button" type="submit">Sign in</button><a class="button-secondary" href="{{ routes.account_register_url }}">Create account</a></div>{% endform %}</div></div></section>