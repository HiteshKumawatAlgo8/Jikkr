<section class="shop-section"><div class="content-width"><div class="shop-card article-content"><div class="section-heading"><h1>Activate account</h1></div>{% form 'activate_customer_password' %}{{ form.errors | default_errors }}<div class="grid grid--2"><div class="field"><label for="CustomerPassword">Password</label><input type="password" name="customer[password]" id="CustomerPassword"></div><div class="field"><label for="CustomerPasswordConfirmation">Confirm password</label><input type="password" name="customer[password_confirmation]" id="CustomerPasswordConfirmation"></div></div><div style="margin-top:20px; display:flex; gap:12px;"><button class="button" type="submit">Activate</button><button class="button-secondary" type="submit" name="decline">Decline</button></div>{% endform %}</div></div></section>